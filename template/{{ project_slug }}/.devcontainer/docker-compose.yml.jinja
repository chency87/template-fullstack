services:
  dev:
    image: {{ project_slug }}-devcontainer
    build:
      context: ..
      dockerfile: .devcontainer/Dockerfile

    container_name: {{ project_slug }}
    init: true

    {% if stack_choice == "agents" %}
    working_dir: /zeroclaw-data
    {% else %}
    working_dir: {{ workspace_dir }}
    {% endif %}

    {% if stack_choice == "agents" %}
    volumes:
      - ..:/zeroclaw-data:cached
      - dev_history:/zeroclaw-data/.history
      - uv_cache:/zeroclaw-data/.cache/uv
    {% else %}
    volumes:
      - ..:{{ workspace_dir }}:cached
      - dev_history:/home/user/.history
      - uv_cache:/home/user/.cache/uv
      {% if with_gpu %}
      - huggingface:/home/user/.cache/huggingface
      {% endif %}


    {% endif %}

    # run as the same user defined in Dockerfile
    user: "1000:1000"

    environment:
      {% if stack_choice == "agents" %}
      - HOME=/zeroclaw-data
      - UV_CACHE_DIR=/zeroclaw-data/.cache/uv
      {% else %}
      - HOME=/home/user
      - UV_CACHE_DIR=/home/user/.cache/uv
      {% if stack_choice == "fullstack" and with_node %}
      - PNPM_HOME=/home/user/.local/share/pnpm
      - PATH=/home/user/.local/share/pnpm:$PATH
      {% endif %}
      {% endif %}

    command: sleep infinity

    {% if with_gpu %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
    {% endif %}


    # optional ports (uncomment if needed)
    # ports:
    #   - "3000:3000"
    #   - "8000:8000"

volumes:
  dev_history:
  uv_cache:
  {% if stack_choice == 'fullstack' and with_gpu %}
  huggingface:
  {% endif %}
