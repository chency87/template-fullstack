services:
  dev:
    image: {{ project_slug }}-devcontainer
    build:
      context: ..
      dockerfile: .devcontainer/Dockerfile
      args:
        USER_UID: ${USER_UID}
        USER_GID: ${USER_GID}

    container_name: {{ project_slug }}
    init: true

    {% if stack_choice == "agents" %}
    working_dir: /zeroclaw-data
    {% else %}
    working_dir: {{ workspace_dir }}
    {% endif %}

    {% if stack_choice == "agents" %}
    volumes:
      - ..:/zeroclaw-data:cached
      - dev_history:/home/user/.history
      - uv_cache:/home/user/.cache/uv
    {% else %}
    volumes:
      - ..:{{ workspace_dir }}:cached
      - dev_history:/home/user/.history
      - uv_cache:/home/user/.cache/uv
      {% if with_gpu %}
      - huggingface:/home/user/.cache/huggingface
      {% endif %}


    {% endif %}

    # run as the same user defined in Dockerfile
    user: "${USER_UID}:${USER_GID}"

    environment:
      {% if stack_choice == "agents" %}
      - HOME=/home/user
      - UV_CACHE_DIR=/home/user/.cache/uv
      {% else %}
      - HOME=/home/user
      - UV_CACHE_DIR=/home/user/.cache/uv
      {% endif %}

    command: sleep infinity

    {% if with_gpu %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
    {% endif %}


    # optional ports (uncomment if needed)
    # ports:
    #   - "3000:3000"
    #   - "8000:8000"

volumes:
  dev_history:
    name: dev_history
  uv_cache:
    name: uv_cache
  {% if stack_choice == 'fullstack' and with_gpu %}
  huggingface:
    name: huggingface_cache
  {% endif %}
