# syntax=docker/dockerfile:1.7

FROM debian:bookworm-slim AS tools-builder

ARG HUGO_VERSION=0.158.0

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL \
    "https://github.com/gohugoio/hugo/releases/download/v${HUGO_VERSION}/hugo_extended_${HUGO_VERSION}_linux-amd64.tar.gz" \
    | tar -xz -C /usr/local/bin hugo \
    && chmod +x /usr/local/bin/hugo \
    && hugo version

RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        -o /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=amd64 signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL \
    "https://github.com/BurntSushi/ripgrep/releases/download/14.1.1/ripgrep-14.1.1-x86_64-unknown-linux-musl.tar.gz" \
    | tar -xz --strip-components=1 -C /usr/local/bin \
        "ripgrep-14.1.1-x86_64-unknown-linux-musl/rg" \
    && rg --version

RUN curl -fsSL \
    "https://github.com/sharkdp/fd/releases/download/v10.2.0/fd-v10.2.0-x86_64-unknown-linux-musl.tar.gz" \
    | tar -xz --strip-components=1 -C /usr/local/bin \
        "fd-v10.2.0-x86_64-unknown-linux-musl/fd" \
    && fd --version

RUN curl -fsSL \
    "https://github.com/casey/just/releases/download/1.40.0/just-1.40.0-x86_64-unknown-linux-musl.tar.gz" \
    | tar -xz -C /usr/local/bin just \
    && just --version

RUN curl -fsSL \
    "https://github.com/XAMPPRocky/tokei/releases/download/v12.1.2/tokei-x86_64-unknown-linux-musl.tar.gz" \
    | tar -xz -C /usr/local/bin tokei \
    && tokei --version

RUN curl -fsSL \
    "https://github.com/mikefarah/yq/releases/download/v4.45.1/yq_linux_amd64" \
    -o /usr/local/bin/yq \
    && chmod +x /usr/local/bin/yq \
    && yq --version

FROM debian:bookworm-slim AS runtime

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

ARG USERNAME=user
ARG USER_UID=1000
ARG USER_GID=1000
ARG PYTHON_VERSION="{{ python_version }}"
ARG NODE_VERSION="{{ node_version }}"
ARG NVM_VERSION="{{ nvm_version }}"
ARG PNPM_VERSION="{{ pnpm_version }}"

ENV DEBIAN_FRONTEND=noninteractive
ENV HOME=/home/user
ENV ZEROCLAW_WORKSPACE=/workspaces/zeroclaw/zeroclaw-data
ENV ZEROCLAW_ALLOW_PUBLIC_BIND=true
ENV SHELL=/bin/bash
ENV VIRTUAL_ENV=/opt/venv
ENV UV_PROJECT_ENVIRONMENT=/opt/venv
ENV UV_CACHE_DIR=/home/user/.cache/uv
ENV UV_TOOL_BIN_DIR=/home/user/.local/bin
ENV CARGO_HOME=/home/user/.cargo
ENV RUSTUP_HOME=/home/user/.rustup
ENV NVM_DIR=/home/user/.nvm
ENV NVM_SYMLINK_CURRENT=true
ENV PIP_USER=false
ENV PYTHONUSERBASE=/home/user/.local
ENV CHROME_PATH=/usr/bin/chromium
ENV CHROMIUM_FLAGS="--no-sandbox --disable-gpu --disable-dev-shm-usage --headless"
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8
ENV PATH=$VIRTUAL_ENV/bin:$UV_TOOL_BIN_DIR:$NVM_DIR/current/bin:/home/user/.cargo/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

RUN printf '#!/bin/sh\nexit 101\n' > /usr/sbin/policy-rc.d \
    && chmod +x /usr/sbin/policy-rc.d

RUN --mount=type=cache,target=/var/cache/apt/ \
    --mount=type=cache,target=/var/lib/apt/ \
    apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
      openssh-client \
      tmux \
      less \
      vim \
      jq \
      tree \
      rsync \
      procps \
      iproute2 \
      iputils-ping \
      dnsutils \
      sqlite3 \
      pkg-config \
      libssl-dev \
      passwd \
      bat \
      sudo \
      zip \
      unzip \
      chromium \
      libnss3 \
      libatk-bridge2.0-0 \
      libgtk-3-0 \
      libx11-xcb1 \
      libxcomposite1 \
      libxdamage1 \
      libxrandr2 \
      libgbm1 \
      libasound2 \
      xvfb \
      gcc \
      g++ \
      make \
    && groupadd --gid $USER_GID $USERNAME \
    && useradd \
      --uid $USER_UID \
      --gid $USER_GID \
      --home-dir $HOME \
      --shell /bin/bash \
      --no-create-home \
      --comment "ZeroClaw agent user" \
      $USERNAME \
    && mkdir -p $VIRTUAL_ENV \
    && echo "$USERNAME ALL=(root) NOPASSWD:ALL" > /etc/sudoers.d/$USERNAME \
    && chmod 0440 /etc/sudoers.d/$USERNAME

RUN curl -sS https://starship.rs/install.sh | sh -s -- -y -b /usr/local/bin

COPY --from=tools-builder /usr/bin/gh /usr/local/bin/gh
COPY --from=tools-builder /usr/local/bin/hugo /usr/local/bin/hugo
COPY --from=tools-builder /usr/local/bin/rg /usr/local/bin/rg
COPY --from=tools-builder /usr/local/bin/fd /usr/local/bin/fd
COPY --from=tools-builder /usr/local/bin/just /usr/local/bin/just
COPY --from=tools-builder /usr/local/bin/tokei /usr/local/bin/tokei
COPY --from=tools-builder /usr/local/bin/yq /usr/local/bin/yq

RUN mkdir -p \
    $HOME/.zeroclaw \
    $ZEROCLAW_WORKSPACE \
    $CARGO_HOME/bin \
    $CARGO_HOME/registry \
    $RUSTUP_HOME \
    $UV_TOOL_BIN_DIR \
    $HOME/.cache/uv \
    $HOME/.config \
    $HOME/.history \
    $HOME/.local/share \
    $NVM_DIR \
    && chown -R $USERNAME:$USERNAME $HOME $VIRTUAL_ENV

RUN ln -sf /usr/bin/batcat /usr/local/bin/bat

RUN git config --system user.email "agent@zeroclaw.local" \
    && git config --system user.name "ZeroClaw Agent" \
    && git config --system init.defaultBranch main \
    && git config --system safe.directory '*'

RUN printf 'export PATH="%s:$PATH"\n' "$VIRTUAL_ENV/bin:$UV_TOOL_BIN_DIR:$NVM_DIR/current/bin" > /etc/profile.d/devcontainer-path.sh

SHELL ["/bin/bash", "-c"]

USER $USERNAME

RUN mkdir -p "$HOME/.local/bin" "$HOME/.local/share"

RUN uv venv --python "${PYTHON_VERSION}" "${VIRTUAL_ENV}"

RUN curl --proto '=https' --tlsv1.2 -fsSL https://sh.rustup.rs | sh -s -- -y --profile minimal \
    && source "$CARGO_HOME/env" \
    && rustup default stable \
    && cargo --version \
    && rustc --version

RUN mkdir -p "$NVM_DIR" \
    && curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v${NVM_VERSION}/install.sh | bash \
    && source "$NVM_DIR/nvm.sh" \
    && nvm install "$NODE_VERSION" \
    && nvm alias default "$NODE_VERSION" \
    && nvm use default \
    && corepack enable \
    && corepack prepare pnpm@${PNPM_VERSION} --activate \
    && npm install -g agent-browser opencode-ai

RUN echo 'export HISTFILE=$HOME/.history/.bash_history' >> "$HOME/.bashrc" \
    && echo 'export HISTSIZE=10000' >> "$HOME/.bashrc" \
    && echo 'export HISTFILESIZE=20000' >> "$HOME/.bashrc" \
    && echo 'export HISTCONTROL=ignoredups:erasedups' >> "$HOME/.bashrc" \
    && echo 'shopt -s histappend' >> "$HOME/.bashrc" \
    && echo 'PROMPT_COMMAND="history -a; history -c; history -r"' >> "$HOME/.bashrc" \
    && echo 'export CARGO_HOME=/home/user/.cargo' >> "$HOME/.bashrc" \
    && echo 'export RUSTUP_HOME=/home/user/.rustup' >> "$HOME/.bashrc" \
    && echo 'export PATH=$VIRTUAL_ENV/bin:$UV_TOOL_BIN_DIR:$NVM_DIR/current/bin:$PATH' >> "$HOME/.bashrc" \
    && echo 'export NVM_DIR=/home/user/.nvm' >> "$HOME/.bashrc" \
    && echo '[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"' >> "$HOME/.bashrc" \
    && echo '[ -s "$CARGO_HOME/env" ] && . "$CARGO_HOME/env"' >> "$HOME/.bashrc" \
    && echo '[ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"' >> "$HOME/.bashrc" \
    && echo 'if [ -f "$HOME/.bashrc" ]; then . "$HOME/.bashrc"; fi' > "$HOME/.bash_profile"

SHELL ["/bin/bash", "-lc"]

EXPOSE 3000
