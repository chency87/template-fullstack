{
  "name": "{{ project_name }}",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "initializeCommand": "sh -c 'printf \"USER_UID=%s\\nUSER_GID=%s\\n\" \"$(id -u)\" \"$(id -g)\" > .devcontainer/.env'",
{% if stack_choice == "agents" %}
  "workspaceFolder": "/workspaces/zeroclaw/src",
  "remoteEnv": {
    "VIRTUAL_ENV": "/opt/venv",
    "PATH": "/opt/venv/bin:${containerEnv:PATH}",
    "UV_PROJECT_ENVIRONMENT": "/opt/venv",
    "ZEROCLAW_WORKSPACE": "/workspaces/zeroclaw/zeroclaw-data"
  },
{% else %}
  "workspaceFolder": "{{ workspace_dir }}",
  "remoteEnv": {
{% if with_gpu %}
    "VIRTUAL_ENV": "/opt/conda",
    "PATH": "/opt/conda/bin:${containerEnv:PATH}",
    "UV_PROJECT_ENVIRONMENT": "/opt/conda"
{% else %}
    "VIRTUAL_ENV": "/opt/venv",
    "PATH": "/opt/venv/bin:${containerEnv:PATH}",
    "UV_PROJECT_ENVIRONMENT": "/opt/venv"
{% endif %}
  },
{% endif %}
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker"{% if stack_choice == "fullstack" and with_node %},
        "dbaeumer.vscode-eslint"{% endif %}
      ],
      "settings": {
{% if stack_choice == "fullstack" and with_gpu %}
        "python.defaultInterpreterPath": "/opt/conda/bin/python",
{% else %}
        "python.defaultInterpreterPath": "/opt/venv/bin/python",
{% endif %}
        "python.terminal.activateEnvironment": false
      }
    }
  },
  "updateRemoteUserUID": false,
  "remoteUser": "user"
}
